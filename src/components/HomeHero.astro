---
import MovableType from './MovableType.tsx';
---
<section class="relative min-h-[90vh] overflow-hidden bg-paper px-8 py-16">
  <!-- sunburst red wedge: layered triangles radiating from top-left corner (El Lissitzky homage) -->
  <svg class="absolute -left-20 -top-20 w-[70vw] h-[70vw] opacity-90" viewBox="0 0 100 100" aria-hidden="true">
    <!-- main red wedge -->
    <polygon points="0,0 100,0 0,100" fill="#8B1A1A" />
    <!-- radiating darker rays -->
    <polygon points="0,0 80,0 0,40" fill="#0A0A0A" opacity="0.85" />
    <polygon points="0,0 50,0 0,80" fill="#8B1A1A" opacity="0.7" />
    <polygon points="0,0 20,0 0,100" fill="#0A0A0A" opacity="0.6" />
    <polygon points="0,0 100,30 60,0" fill="#8B1A1A" opacity="0.5" />
    <polygon points="0,0 100,15 90,0" fill="#0A0A0A" opacity="0.4" />
  </svg>
  <div class="hero-tilt relative z-10 max-w-[1440px] mx-auto">
    <MovableType client:load text="CHUI SIU FAI" className="hero-name font-display leading-[0.85] text-ink-black" />
    <p class="font-mono text-sm md:text-2xl mt-6 text-paper bg-ink-black inline-block px-3 py-1">
      DESIGNER · ENGINEER · AUTEUR
    </p>
  </div>
  <div class="absolute bottom-8 right-8 flex flex-col items-end gap-2">
    <span class="font-mono text-xs text-ink-black">↓ scroll · 6 sections</span>
    <span class="bg-ink-yellow text-ink-black font-mono text-xs font-bold px-2 py-1 inline-block">
      HK / GLOBAL
    </span>
  </div>
</section>
<style>
  .hero-tilt {
    transform: rotate(-7deg);
    transform-origin: left top;
  }
  .hero-name {
    font-size: clamp(2.5rem, 13vw, 18rem);
  }
  @media (max-width: 768px) {
    .hero-tilt {
      transform: rotate(0deg);
    }
  }
</style>
