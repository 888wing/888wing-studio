---
import '../styles/global.css';
import GridOverlay from '../components/GridOverlay.astro';
import RegistrationCursor from '../components/RegistrationCursor.astro';
import MotionProvider from '../components/MotionProvider.astro';
import RedWedge from '../components/RedWedge.astro';
import TopStrip from '../components/TopStrip.tsx';
import SEO from '../components/SEO.astro';
import { ViewTransitions } from 'astro:transitions';
const { title = 'CHUI SIU FAI' } = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO title={title} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" href="/textures/paper-noise.jpg" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@125,900&family=JetBrains+Mono:wght@400;700&family=Noto+Sans+TC:wght@400;900&family=Noto+Serif+TC:wght@900&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@125,900&family=JetBrains+Mono:wght@400;700&family=Noto+Sans+TC:wght@400;900&family=Noto+Serif+TC:wght@900&display=swap" rel="stylesheet" />
    <ViewTransitions />
  </head>
  <body>
    <TopStrip client:load />
    <div class="paper-noise pointer-events-none fixed inset-0 z-[5] mix-blend-multiply opacity-15" aria-hidden="true"
         style="background-image: url('/textures/paper-noise.jpg'); background-repeat: repeat;"></div>
    <MotionProvider />
    <GridOverlay />
    <RegistrationCursor />
    <RedWedge />
    <slot />
  </body>
</html>
